# Frontend environment.
#
# Where the Railway backend (Dalivim escrow API) lives. This value is baked
# into the static build by scripts/gen-config.mjs (runs before `dev`/`build`)
# and exposed to the bundles as window.DALIVIM_API_BASE_URL.
#
# Set this in the Cloudflare Pages project (Settings → Environment variables)
# to point the deployed frontend at a different backend. No trailing slash.
NEXT_PUBLIC_API_BASE_URL=https://dalivim-escrow-production.up.railway.app
